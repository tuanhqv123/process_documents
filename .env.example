# PostgreSQL Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pdf_processor

# Embedding service
EMBEDDING_SERVICE_URL=http://localhost:8001
EMBEDDING_DIM=384

# Redis
REDIS_URL=redis://localhost:6379

# ── OCR / LLM Configuration ────────────────────────────────────────
# OpenAI-compatible OCR endpoint (dots.ocr vision model)
DOTS_OCR_URL=
DOTS_OCR_MODEL=rednote-hilab/dots.ocr

# OpenAI-compatible LLM endpoint (optional, for image description)
VLLM_URL=
VLLM_API_KEY=
VLLM_MODEL=

# OCR processing tuning
OCR_PARALLEL_WORKERS=5
OCR_MAX_RETRIES=2
